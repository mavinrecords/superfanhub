# =============================================================
# Mavin SuperFan Hub — environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit `.env` itself (already in .gitignore).
# =============================================================

# ----- Server -----
PORT=3000
NODE_ENV=development
# Used for OAuth callback construction and email links.
BASE_URL=http://localhost:3000

# ----- Database -----
# Absolute path to the SQLite file. Default puts it inside the repo at
# src/db/giftcards.db (fine for local dev). On any production host you MUST
# point this at a path INSIDE A MOUNTED PERSISTENT DISK or your data is wiped
# every redeploy. Examples:
#   Render Starter+ with disk mounted at /data       → DB_PATH=/data/giftcards.db
#   Fly.io with volume mounted at /data              → DB_PATH=/data/giftcards.db
# Leave unset for local dev.
DB_PATH=

# ----- Sessions -----
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ----- Initial admin (only used by `npm run init-db` on a FRESH database) -----
# Set these BEFORE running init-db on Render to avoid the default admin/admin123 seed.
# If ADMIN_PASSWORD is set explicitly, the must_change_password flag is NOT set.
# Once the admin user exists, these env vars are ignored — rotate via the /admin UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----- Spotify OAuth (optional — enables Spotify connect on /dashboard) -----
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Comma-separated Spotify artist IDs to seed the Mavin artist roster on boot.
# Example: MAVIN_ARTIST_IDS=4ESXCZRGcg6f8bF2a4LcvL,5jrdCoLpJSV...
MAVIN_ARTIST_IDS=

# ----- Last.fm (optional — enables Last.fm scrobble pulls) -----
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

# ----- Email / SMTP (optional — enables transactional email) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mavin SuperFan Hub <noreply@example.com>"

# ----- Schedulers -----
# Set to "true" to run the reward-expiry sweep once at boot.
# (The cron job in src/services/scheduler.js still runs daily either way.)
RUN_EXPIRY_CHECK_ON_START=false
