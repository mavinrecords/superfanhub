<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <meta name="description" content="Redeem your gift card or apply discounts to your ticket purchase">
  <title>Gift Card Redemption</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: var(--space-xl);
      padding-bottom: calc(var(--space-xl) + 60px);
      text-align: center;
      background: #000000;
    }

    .hero-title {
      margin-bottom: var(--space-sm);
      font-size: 1.75rem;
      font-weight: 700;
      color: #ffffff;
      text-transform: lowercase;
    }

    .hero-subtitle {
      color: var(--text-secondary);
      margin-bottom: var(--space-2xl);
      max-width: 320px;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    .redeem-card {
      width: 100%;
      max-width: 400px;
    }

    .hero-title {
      margin-bottom: var(--space-md);
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.7) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative;
      z-index: 1;
    }

    .hero-subtitle {
      color: var(--text-secondary);
      margin-bottom: var(--space-2xl);
      max-width: 340px;
      font-size: 1rem;
      line-height: 1.6;
      position: relative;
      z-index: 1;
    }

    .redeem-card {
      width: 100%;
      max-width: 440px;
      position: relative;
      z-index: 1;
    }

    .result-section {
      margin-top: var(--space-xl);
    }

    .action-buttons {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      margin-top: var(--space-xl);
    }

    .secondary-action {
      text-align: center;
      margin-top: var(--space-md);
    }

    .footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      padding: var(--space-md);
      text-align: center;
      font-size: 0.75rem;
      color: var(--text-muted);
      background: rgba(9, 9, 11, 0.9);
      backdrop-filter: blur(10px);
      border-top: 1px solid var(--border-color);
    }

    .footer a {
      color: var(--text-muted);
      opacity: 0.6;
      transition: var(--transition-fast);
    }

    .footer a:hover {
      opacity: 1;
      color: var(--primary-light);
    }

    @media (min-width: 481px) {
      .hero-title {
        font-size: 2.75rem;
      }

      .action-buttons {
        flex-direction: row;
      }

      .action-buttons .btn {
        flex: 1;
      }
    }
  </style>
</head>

<body>
  <style>
    .super-header {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: var(--space-lg);
      text-align: center;
    }

    .hero {
      <div class="super-header">Superfans Redemption Panel</div><h1 class="hero-title">Redeem Gift Card</h1><p class="hero-subtitle">Enter your gift card code to check your balance.</p><div class="card redeem-card">< !-- Code Entry Form --><form id="validateForm"><label class="form-label text-center" style="display:block; margin-bottom: var(--space-md);">Gift Card Code</label>< !-- Status Banner placeholder --><div id="statusBanner" class="status-banner hidden"></div><div class="code-input-group"><input type="text" class="code-segment" id="code1" maxlength="4" inputmode="text" autocomplete="off"
      autofocus><span class="code-separator">-</span><input type="text" class="code-segment" id="code2" maxlength="4" inputmode="text" autocomplete="off"><span class="code-separator">-</span><input type="text" class="code-segment" id="code3" maxlength="4" inputmode="text" autocomplete="off"><span class="code-separator">-</span><input type="text" class="code-segment" id="code4" maxlength="4" inputmode="text" autocomplete="off"></div><button type="submit" class="btn btn-primary btn-lg w-full" id="validateBtn">Apply Card </button></form>< !-- Card Balance Display (Success state) --><div id="cardResult" class="result-section hidden"><h2 class="text-center mb-lg" style="font-size:1.25rem;">Card Balance</h2><div class="gift-card-display card-shimmer" id="giftCardDisplay"><div class="gift-card-content"><div class="gift-card-tier" id="cardTier">PREMIUM</div><div id="cardValueSection"><div class="gift-card-balance" id="cardBalance">$0.00</div></div><div id="cardDiscountSection" class="hidden"><div class="gift-card-discount" id="cardDiscount">0% OFF</div><div class="text-muted mt-md" id="cardUses"></div></div><div class="gift-card-code" id="cardCodeDisplay">••••-••••-••••-••••</div><div class="gift-card-expiry" id="cardExpiry"></div></div></div>< !-- Primary Action (Contextual) --><div class="action-buttons" id="actionButtons"><button class="btn btn-primary btn-lg" id="primaryActionBtn">Apply $0.00 to Cart</button></div><div class="secondary-action" id="secondaryAction"><button class="action-link" id="secondaryActionBtn">Or apply as discount →</button></div></div>< !-- Redeem Value Form --><div id="redeemSection" class="result-section hidden"><h3 class="mb-lg">Redeem Value</h3><form id="redeemForm"><div class="form-group"><label class="form-label" for="redeemAmount">Amount to Redeem</label><input type="number" id="redeemAmount" class="form-input" placeholder="0.00" step="0.01" min="0.01"
      inputmode="decimal" required></div><div class="action-buttons"><button type="button" class="btn btn-secondary" id="cancelRedeem">Cancel</button><button type="submit" class="btn btn-primary" id="confirmRedeem">Confirm</button></div></form></div>< !-- Apply Discount Form --><div id="discountSection" class="result-section hidden"><h3 class="mb-lg">Apply Discount</h3><form id="discountForm"><div class="form-group"><label class="form-label" for="ticketAmount">Ticket Amount ($)</label><input type="number" id="ticketAmount" class="form-input" placeholder="0.00" step="0.01" min="0.01"
      inputmode="decimal" required></div><div class="form-group"><label class="form-label" for="ticketId">Ticket/Order ID</label><input type="text" id="ticketId" class="form-input" placeholder="Enter ticket or order ID" required></div><div id="discountPreview" class="alert alert-info hidden mb-lg"><span id="discountPreviewText"></span></div><div class="action-buttons"><button type="button" class="btn btn-secondary" id="cancelDiscount">Cancel</button><button type="submit" class="btn btn-primary" id="confirmDiscount">Apply</button></div></form></div></div></main>< !-- Toast Container --><div id="toastContainer" class="toast-container"></div><footer class="footer"><a href="/admin">Admin</a></footer><script src="/js/redemption.js"></script></body></html>